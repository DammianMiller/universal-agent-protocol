{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "llama.cpp": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llama-server (local)",
      "options": {
        "baseURL": "http://localhost:8080/v1",
        "apiKey": "sk-qwen35b"
      },
      "models": {
        "qwen35-a3b-iq4xs": {
          "name": "Qwen3.5 35B A3B (IQ4_XS)",
          "limit": {
            "context": 262144,
            "output": 16384
          }
        }
      }
    }
  },
  "model": "llama.cpp/qwen35-a3b-iq4xs",
  "agent": {
    "build": {
      "model": "llama.cpp/qwen35-a3b-iq4xs",
      "temperature": 0.1
    },
    "plan": {
      "model": "llama.cpp/qwen35-a3b-iq4xs",
      "temperature": 0.2
    },
    "memory": {
      "model": "llama.cpp/qwen35-a3b-iq4xs",
      "temperature": 0
    },
    "review": {
      "model": "llama.cpp/qwen35-a3b-iq4xs",
      "temperature": 0.1
    }
  },
  "mcp": {
    "uap-router": {
      "command": "node",
      "args": ["./dist/mcp-router/server.js"],
      "env": {
        "UAP_PROJECT_DIR": ".",
        "UAP_MEMORY_DB": "./agents/data/memory/short_term.db",
        "UAP_COORD_DB": "./agents/data/coordination/coordination.db"
      }
    }
  }
}
