{
  "$schema": "./config.schema.json",
  "agent": {
    "default_model": "qwen3.5-a3b-iq4xs",
    "api_endpoint": "http://192.168.1.165:8080/v1"
  },

  "prompt_settings": {
    "use_qwen35_optimized_params": true,
    "default_mode": "thinking",
    "settings_file": "../config/qwen35-settings.json"
  },

  "model": {
    "max_tokens": 4096,
    "timeout_ms": 120000,
    "stop_sequences": ["<tool_call>", "</tool_call>"],
    "temperature": 0.7,
    "top_p": 0.95
  }
}
