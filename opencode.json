{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "qwen-proxy": {
      "npm": "@ai-sdk/anthropic",
      "name": "llama guardrail proxy (local)",
      "options": {
        "baseURL": "http://127.0.0.1:4000/v1",
        "apiKey": "sk-qwen35b",
        "chunkTimeout": 45000
      },
      "models": {
        "qwen35-a3b-iq4xs": {
          "name": "Qwen3.5 35B A3B (IQ4_XS via proxy)",
          "reasoning": false,
          "tool_call": true,
          "limit": {
            "context": 262144,
            "output": 81920
          }
        }
      }
    },
    "llama.cpp-direct": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llama-server direct (fallback)",
      "options": {
        "baseURL": "http://127.0.0.1:8080/v1",
        "apiKey": "sk-qwen35b"
      },
      "models": {
        "qwen35-a3b-iq4xs": {
          "name": "Qwen3.5 35B A3B (IQ4_XS direct)",
          "limit": {
            "context": 262144,
            "output": 81920
          }
        }
      }
    }
  },
  "model": "qwen-proxy/qwen35-a3b-iq4xs",
  "agent": {
    "build": {
      "model": "qwen-proxy/qwen35-a3b-iq4xs",
      "temperature": 0.1
    },
    "plan": {
      "model": "qwen-proxy/qwen35-a3b-iq4xs",
      "temperature": 0.2
    },
    "memory": {
      "model": "qwen-proxy/qwen35-a3b-iq4xs",
      "temperature": 0
    },
    "review": {
      "model": "qwen-proxy/qwen35-a3b-iq4xs",
      "temperature": 0.1
    }
  }
