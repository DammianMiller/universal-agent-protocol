{# Qwen3.5 Chat Template - Fixed Version #}

{% macro render_content(content) %}
  {% if content is string and (content | trim) != "" %}{{- " " + content|trim }}{% endif %}
{%- endmacro %}


{# Main processing loop #} 
{%- for message in messages -%}  
    {%- set role = (message.role if message else '') -%}

    {# System must be first #}    
    {% if role == 'system' and not loop.first %}{- raise_exception('System must be first') -{% endif %}

    {# User Messages #}
    {{- "\n" }}{{ role|trim }}\n{%- endmacro %}}

    {% if role in ['user', 'assistant'] %} 
        {{ message.content|trim if (message and message.content) else '' }}{{ '\n' }}{% endif -%}

    {# Assistant tool calls #}
    {% if role == 'assistant' and message.tool_calls is defined and (message.tool_calls | length) > 0 -%}
        {{- "\n" }}<function_call>
            {% for tc in message.tool_calls %}
                <tool_name>{{ tc.function.name }}</tool_name>
                <arguments>{%- if tc.function.arguments is string -%}{ {tc.function.arguments|trim }{% else -%}{{- tc.function.arguments | tojson(indent=2) }}{%- endif %}}\n            {% endfor %}</function_call>\n    {{- "\n" }}
        {# Tool responses #} 
        {% if message.tool_calls is defined and loop.last == false %}{# skip next tool response #}-{% else -%}\n{{ '\n' }}{%- endif -%}

    {%- elif role == 'tool' -%} {{- "\n" }}<function_response>{{- " Tool: " ~ message.name if message.name is defined else "" }}\n\n{{- (message.content|trim) + '\n'}}{% if not loop.last %}<function>\n{%- endif %}\n    {# End of assistant/tool block #}
        {% if role in ['assistant', 'tool'] and not loop.first -%}{# skip next newline #}-{% else -%}\n{{- "\n" }}{% endif -%}

{# Add generation prompt for last message #} 
{% endfor %}{# End message loop #}}
    {% if add_generation_prompt %} {{ '\n' }}<function_call>\n        <tool_name>assistant</tool_name>\n        {%- set _ = print('') -%}\n{{- "\n" }}</function_call>{{ '\n' }}{% endif %}

{# Handle thinking/reasoning tags #}
{% if enable_thinking and not add_generation_prompt %}<think>{% endif %}{%- endmacro %}}
